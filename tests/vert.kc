
import sgpu;

struct VertexOutput {
    #[builtin(position)]
    position: vec4<f32>,
    #[location(0)]
    color: vec3<f32>,
};

const POSITIONS: [vec2<f32>; 3] = {
  vec2(0.0, -0.5),
  vec2(0.5, 0.5),
  vec2(-0.5, 0.5),
};

const COLORS: [vec3<f32>; 3] = {
  vec3<f32>(1.0, 0.0, 0.0),
  vec3<f32>(0.0, 1.0, 0.0),
  vec3<f32>(0.0, 0.0, 1.0),
};

[shader("vertex")]
VertexOutput main() {
  VertexOutput out;
  out.position = vec4(POSITIONS[_vertex_id].x, POSITIONS[_vertex_id].y, 0.0, 1.0);
  out.color = COLORS[_vertex_id];
  return out;
}
